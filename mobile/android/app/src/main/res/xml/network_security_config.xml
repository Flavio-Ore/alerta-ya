<?xml version="1.0" encoding="utf-8"?>
<!--
  AlertaYa — política de red.

  Producción usa HTTPS (por default Android lo permite).
  En desarrollo permitimos cleartext HTTP únicamente a IPs de red local
  (Wi-Fi del Mac, emulador Android, dispositivo en LAN). Esto evita
  abrir HTTP a cualquier dominio externo.

  Si tu Mac tiene otra IP local, agregala como <domain> abajo.
-->
<network-security-config>
    <!-- Producción: HTTPS por default -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- Desarrollo: HTTP plano sólo a estas IPs locales -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Emulador Android (10.0.2.2 = host) y localhost -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>

        <!-- IPs de Mac en WiFi (agregar las que uses) -->
        <domain includeSubdomains="false">192.168.18.21</domain>
        <domain includeSubdomains="false">192.168.0.151</domain>
    </domain-config>
</network-security-config>
