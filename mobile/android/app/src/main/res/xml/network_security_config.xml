<?xml version="1.0" encoding="utf-8"?>
<!--
  AlertaYa — política de red (producción).

  Solo HTTPS con anchors del sistema. El cleartext HTTP para desarrollo
  local (emulador, localhost, IPs de LAN) vive en la variante debug:
  android/app/src/debug/res/xml/network_security_config.xml
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
