// firebase.storage.rules
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Evidencia de reportes: el ciudadano sube solo a su propio UID.
    // Nadie puede leer desde el cliente — solo el backend con Admin SDK.
    match /reports/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if false;
    }

    // Bloques de audio cifrados del pánico: cualquier usuario autenticado puede subir.
    // NADIE puede leer desde el cliente — solo el backend con Admin SDK.
    match /panic/{allPaths=**} {
      allow write: if request.auth != null;
      allow read: if false;
    }
  }
}
