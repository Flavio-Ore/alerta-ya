{
  "name": "alertaya-api",
  "version": "1.0.0",
  "description": "AlertaYa — Backend API Node.js",
  "main": "dist/index.js",
  "scripts": {
    "dev":              "bun --watch src/index.ts",
    "build":            "tsc",
    "start":            "bun dist/index.js",
    "lint":             "eslint . --ext .ts",
    "test":             "vitest run",
    "test:watch":       "vitest",
    "test:coverage":    "vitest run --coverage",
    "prisma:generate":  "bunx prisma generate",
    "prisma:migrate":   "bunx prisma migrate dev",
    "prisma:validate":  "bunx prisma validate",
    "prisma:seed":      "bun prisma/seed.ts"
  },
  "dependencies": {
    "express":                "^4.19.0",
    "firebase-admin":         "^12.1.0",
    "helmet":                 "^7.1.0",
    "express-rate-limit":     "^7.2.0",
    "ioredis":                "^5.3.2",
    "bcryptjs":               "^2.4.3",
    "jsonwebtoken":           "^9.0.2",
    "@prisma/client":         "^5.13.0",
    "prisma":                 "^5.13.0",
    "zod":                    "^3.23.0",
    "socket.io":              "^4.7.5",
    "@google-cloud/storage":  "^7.10.0",
    "winston":                "^3.13.0",
    "cors":                   "^2.8.5",
    "compression":            "^1.7.4",
    "uuid":                   "^9.0.1"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "devDependencies": {
    "@types/express":                  "^4.17.21",
    "@types/bcryptjs":                 "^2.4.6",
    "@types/jsonwebtoken":             "^9.0.6",
    "@types/cors":                     "^2.8.17",
    "@types/compression":              "^1.7.5",
    "@types/uuid":                     "^9.0.8",
    "@types/bun":                      "latest",
    "typescript":                      "^5.4.0",
    "@typescript-eslint/eslint-plugin":"^7.0.0",
    "@typescript-eslint/parser":       "^7.0.0",
    "eslint":                          "^8.57.0",
    "vitest":                          "^1.6.0",
    "@vitest/coverage-v8":             "^1.6.0",
    "supertest":                       "^7.0.0",
    "@types/supertest":                "^6.0.2"
  }
}
