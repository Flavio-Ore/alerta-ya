# Entorno
NODE_ENV=development
PORT=3000

# Demo mode — bypassa los umbrales del threshold engine.
# Con DEMO_MODE=true, UN solo reporte publica el incidente al panel de
# autoridades inmediatamente (severidad MODERATE por default, o CRITICAL si
# el reporte indica arma/heridos). En producción debe ir en false o ausente.
DEMO_MODE=true

# PostgreSQL + PostGIS
DATABASE_URL=postgresql://alertaya:alertaya@localhost:5432/alertaya_dev

# Redis
REDIS_URL=redis://localhost:6379

# Firebase Admin SDK
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com
# La private key tiene saltos de línea — usar \n en una sola línea
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Cloud Storage — bucket PRIVADO para grabaciones cifradas
GCS_BUCKET_NAME=alertaya-panic-recordings
GCP_PROJECT_ID=tu-proyecto-gcp

# CORS — URL del panel web
WEB_URL=http://localhost:5173

# Microservicio ML
ML_SERVICE_URL=http://localhost:8000

# JWT — mínimo 32 caracteres
JWT_SECRET=cambia-esto-por-un-secret-seguro-minimo-32-chars

# Jobs — Cloud Scheduler manda este valor en header X-Job-Secret
JOB_SECRET=cambia-esto-en-produccion-minimo-16-chars

# GLM (Zhipu) — asistente IA de redacción de mensajes para autoridades.
# Opcional: sin key, el botón "Sugerir con IA" responde 503 (queda deshabilitado).
GLM_API_KEY=tu-glm-api-key
# Defaults (no hace falta cambiarlos):
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4-flash
# La búsqueda web y los modelos con razonamiento pueden tardar más de 20 segundos.
GLM_TIMEOUT_MS=60000

# GLM Vision — verificación de relevancia visual (modelo multimodal, más rápido que GLM-4).
# Usa la misma GLM_API_KEY. Defaults seguros para producción:
GLM_VISION_MODEL=glm-4v-flash
# Tiempo máximo de espera para la llamada de visión (ms). Separado del timeout de chat.
GLM_VISION_TIMEOUT_MS=3000

# Firebase Storage — REQUERIDO en producción para la verificación visual.
# Formato: tu-proyecto.appspot.com (sin gs:// ni https://).
# Sin este valor, la verificación visual se omite (fail-open, score ML sin cambios).
FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com

# Multiplicador de visión — peso del signal visual sobre el score ML.
# 0.0 = visión desactivada, 0.2 = efecto moderado (default). Ajustable sin redeploy.
VISION_SCORE_K=0.2
