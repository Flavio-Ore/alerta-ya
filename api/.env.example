# Entorno
NODE_ENV=development
PORT=3000

# PostgreSQL + PostGIS
DATABASE_URL=postgresql://alertaya:alertaya@localhost:5432/alertaya_dev

# Redis
REDIS_URL=redis://localhost:6379

# Firebase Admin SDK
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com
# La private key tiene saltos de línea — usar \n en una sola línea
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Cloud Storage — bucket PRIVADO para grabaciones cifradas
GCS_BUCKET_NAME=alertaya-panic-recordings
GCP_PROJECT_ID=tu-proyecto-gcp

# CORS — URL del panel web
WEB_URL=http://localhost:5173

# Microservicio ML
ML_SERVICE_URL=http://localhost:8000

# JWT — mínimo 32 caracteres
JWT_SECRET=cambia-esto-por-un-secret-seguro-minimo-32-chars
