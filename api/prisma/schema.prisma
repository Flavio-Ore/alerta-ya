// AlertaYa — Prisma Schema
// Fuente: docs/architecture/DATA_MODELS.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tipos de incidente (MVP: solo ROBBERY y ACCIDENT tienen formulario completo)
enum IncidentType {
  ROBBERY
  ACCIDENT
  HARASSMENT
  EXTORTION
  SUSPICIOUS
}

enum Severity {
  LOW
  MODERATE
  CRITICAL
}

enum IncidentStatus {
  ACTIVE
  IN_ATTENTION
  CLOSED
}

enum PanicStatus {
  ACTIVE
  DEACTIVATED
  TIMEOUT
}

enum NotificationType {
  INCIDENT_NEW           // Nuevo incidente publicado cerca del usuario
  INCIDENT_UPDATED       // Incidente escaló de severidad
  INCIDENT_STATUS_UPDATE // Autoridad actualizó el estado con feedback
  ZONE_RISK              // Zona de alto riesgo predicha por ML
  PANIC_RESOLVED         // Sesión de pánico resuelta (para el propio usuario)
}

// NUNCA almacenar email/nombre en texto plano
// Datos de identidad en tabla separada cifrada (fuera del MVP)
model User {
  id              String          @id @default(uuid())
  firebaseUid     String          @unique // Cifrado en reposo
  reputationScore Int             @default(100)
  createdAt       DateTime        @default(now())
  reports         Report[]
  panicSessions   PanicSession[]
  deviceTokens    DeviceToken[]
  notifications   Notification[]
  preferences     UserPreference?

  @@map("users")
}

// Preferencias del ciudadano — no expone PII
model UserPreference {
  id                String   @id @default(uuid())
  userId            String   @unique
  alertRadiusMeters Int      @default(2000) // Radio para recibir alertas push (metros)
  muteNotifications Boolean  @default(false)
  // Panic features togglables. GPS NO es configurable — siempre se transmite al panel.
  panicRecordAudio  Boolean  @default(true)
  panicAlarmSound   Boolean  @default(true)
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// Incidentes publicados — anónimos, nunca exponen reportante
model Incident {
  id           String         @id @default(uuid())
  type         IncidentType
  severity     Severity
  status       IncidentStatus @default(ACTIVE)
  lat          Float
  lng          Float
  district     String
  confirmCount Int            @default(0)
  denyCount    Int            @default(0)
  reportCount  Int            @default(1)
  expiresAt    DateTime
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  unitAssigned  String?        // ID de unidad operativa asignada
  feedback      String?        // Mensaje de la autoridad visible al ciudadano (max 200 chars)
  aiScore       Float?         // Confianza del verificador ML (0–1) — null si la IA no corrió
  aiVerified    Boolean?       // true si el reporte pasó el verificador ML
  photoTakenAt  DateTime?      // Timestamp EXIF de la foto adjunta (o device_clock si no hay EXIF)
  photoSource   String?        // 'exif' | 'device_clock'
  reports       Report[]
  notifications Notification[]
  statusHistory IncidentStatusHistory[]

  @@map("incidents")
}

// Historial de cambios de estado — auditoría inmutable
model IncidentStatusHistory {
  id         String         @id @default(uuid())
  incidentId String
  status     IncidentStatus
  feedback   String?        // Mensaje adjunto al cambio
  actorUid   String         // Firebase UID de quien actuó
  actorRole  String         // 'AUTHORITY' | 'ADMIN'
  changedAt  DateTime       @default(now())
  incident   Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, changedAt])
  @@map("incident_status_history")
}

// Reportes individuales — identidad nunca sale de aquí
model Report {
  id         String    @id @default(uuid())
  incidentId String?   // null = aún no alcanzó threshold de publicación
  userId     String    // Solo para rate limiting interno, NUNCA expuesto
  formData   Json      // JSONB: respuestas del formulario dinámico
  mediaUrls  String[]  // URLs en GCS — cifradas AES-256
  lat        Float
  lng        Float
  aiVerified Boolean?
  aiScore    Float?
  photoTakenAt DateTime? // Timestamp EXIF de la foto adjunta (o device_clock si no hay EXIF) — por reporte
  photoSource  String?   // 'exif' | 'device_clock'
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
  incident   Incident? @relation(fields: [incidentId], references: [id])

  @@map("reports")
}

model PanicSession {
  id            String      @id @default(uuid())
  userId        String
  startedAt     DateTime    @default(now())
  endedAt       DateTime?
  recordingUrls String[]    // GCS URLs — cifradas AES-256 (legacy, ver RecordingBlock)
  lat           Float
  lng           Float
  status        PanicStatus @default(ACTIVE)
  deactivatedBy String?     // "pin" | "timeout"
  user          User        @relation(fields: [userId], references: [id])
  locationPoints PanicLocationPoint[]
  escrowKey      PanicSessionKey?
  recordingBlocks RecordingBlock[]

  @@map("panic_sessions")
}

// Clave AES-256 de la sesión, envuelta con la pública RSA-OAEP-256 de Cloud KMS.
// El backend nunca guarda ni ve la clave en claro — solo este ciphertext.
model PanicSessionKey {
  id             String   @id @default(uuid())
  panicSessionId String   @unique
  panicSession   PanicSession @relation(fields: [panicSessionId], references: [id], onDelete: Cascade)
  wrappedKey     Bytes
  kmsKeyName     String
  kmsKeyVersion  String
  algorithm      String
  createdAt      DateTime @default(now())

  @@map("panic_session_keys")
}

// Bloque de audio cifrado subido a Storage — reemplaza recordingUrls (nunca poblado).
model RecordingBlock {
  id             String   @id @default(uuid())
  panicSessionId String
  panicSession   PanicSession @relation(fields: [panicSessionId], references: [id], onDelete: Cascade)
  blockIndex     Int
  storagePath    String        // gs://bucket/path — no URL pública
  uploadedAt     DateTime @default(now())

  @@unique([panicSessionId, blockIndex])
  @@map("recording_blocks")
}

// Bitácora inmutable de cada intento de recuperar la clave de una sesión.
model KeyAccessAudit {
  id             String   @id @default(uuid())
  panicSessionId String
  requestedById  String
  requestedAt    DateTime @default(now())
  ipAddress      String?
  result         String        // "SUCCESS" | "DENIED" | "ERROR"

  @@index([panicSessionId, requestedAt])
  @@map("key_access_audits")
}

model PanicLocationPoint {
  id        String       @id @default(uuid())
  sessionId String
  lat       Float
  lng       Float
  createdAt DateTime     @default(now())
  session   PanicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("panic_location_points")
}

// Token FCM del dispositivo — para push notifications por zona
// Se crea/actualiza en login. Redis indexa por distrito para rapidez,
// pero este registro es el backup persistente ante flushes de Redis.
model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique // Token FCM — único por dispositivo
  district  String           // Último distrito conocido del usuario
  // proxTile: key del tile de proximidad (formato "prox:<latTile>:<lngTile>" con
  // TILE_SIZE=0.003°). Permite filtrar FCM por área específica (~330m), no solo
  // por distrito. Nullable: tokens viejos siguen funcionando sin esta info.
  proxTile  String?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([district]) // Lookup rápido: "todos los tokens del distrito X"
  @@index([proxTile]) // Lookup rápido: "todos los tokens en el tile X"
  @@map("device_tokens")
}

// Historial de notificaciones push — alimenta el tab "Alertas" en mobile
// NUNCA almacena datos del reportante — solo info pública del incidente
model Notification {
  id         String           @id @default(uuid())
  userId     String
  type       NotificationType
  title      String
  body       String
  incidentId String?          // FK opcional — null para notifs de zona/risk
  readAt     DateTime?        // null = no leída
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id])
  incident   Incident?        @relation(fields: [incidentId], references: [id])

  @@index([userId, readAt]) // Consulta común: notifs no leídas de un usuario
  @@map("notifications")
}

// Caché de predicciones IA — actualizado por el microservicio ML
model RiskZone {
  id            String   @id @default(uuid())
  district      String
  lat           Float
  lng           Float
  riskScore     Int      // 0–100
  predictedHour Int      // 0–23
  updatedAt     DateTime @updatedAt

  @@map("risk_zones")
}
